{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "outDir": "test-lib",
    "rootDir": ".",
    "paths": {
      "@/*": ["./*"]
    },
    "baseUrl": ".",
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "data/diagnosisMap.ts",
    "data/diagnosisTree.ts",
    "features/learning/history-types.ts",
    "features/learning/types.ts",
    "features/learning/home-journey-state.ts",
    "features/learner/types.ts",
    "features/learner/learner-profile-builders.ts",
    "features/quiz/types.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "functions",
    "node_modules"
  ]
}
