# GA4 Measurement Protocol (Firebase 앱 스트림)
# Firebase 콘솔 > Project Settings > 앱 섹션에서 App ID 확인
# GA4 콘솔 > Admin > Data Streams > 해당 스트림 > Measurement Protocol API secrets > Create

EXPO_PUBLIC_GA4_FIREBASE_APP_ID_IOS=1:xxxxxxxxx:ios:xxxxxxxxxxxxxxxx
EXPO_PUBLIC_GA4_FIREBASE_APP_ID_ANDROID=1:xxxxxxxxx:android:xxxxxxxxxxxxxxxx
EXPO_PUBLIC_GA4_API_SECRET_IOS=<GA4 dasida-ios stream API Secret>
EXPO_PUBLIC_GA4_API_SECRET_ANDROID=<GA4 dasida-android stream API Secret>
